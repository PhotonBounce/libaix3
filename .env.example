# OpsBrief Environment Variables
# Copy this file to .env and fill in your secrets

# ── Database ──────────────────────────────────────────────────────
# For Docker deployments (production):
# NOTE: the password in DATABASE_URL must match POSTGRES_PASSWORD below.
DATABASE_URL=postgresql://opsbrief:change-me-in-production@db:5432/opsbrief
# For local dev with SQLite:
# DATABASE_URL=sqlite:///./data/opsbrief.db
POSTGRES_PASSWORD=change-me-in-production
REDIS_PASSWORD=change-me-in-production

# ── Redis / Celery ────────────────────────────────────────────────
# Docker service name (use localhost for local dev)
REDIS_URL=redis://:change-me-in-production@redis:6379/0
CELERY_BROKER_URL=redis://:change-me-in-production@redis:6379/0
CELERY_RESULT_BACKEND=redis://:change-me-in-production@redis:6379/0

# ── Security ────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-openssl-rand-base64-32
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-base64-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Admin ───────────────────────────────────────────────────────────
ADMIN_API_KEY=change-me-in-production

# ── CORS ────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Leave empty for "*" in dev.
CORS_ORIGINS=
# For production:
# CORS_ORIGINS=https://opsbrief.com,https://app.opsbrief.com

# ── OpenAI ──────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# ── Data sources ────────────────────────────────────────────────────
NVD_API_KEY=
GITHUB_TOKEN=ghp_your-github-token-here
STACKEXCHANGE_API_KEY=

# ── Notifications ───────────────────────────────────────────────────
FCM_SERVER_KEY=

# ── App Constants ───────────────────────────────────────────────────
MAX_ITEMS_PER_SOURCE=500
FREE_DAILY_BRIEFINGS=1
FREE_DAILY_CHATS=5
FREE_SAVED_ITEMS=50
